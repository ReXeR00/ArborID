# ---- Python / Build ----
__pycache__/
*.py[cod]
*.egg-info/
.build/
dist/
build/

# ---- Environments ----
.env
.venv
venv/
env/
*.env

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_convert/
# (optional) hide local notebook autosaves
*.autosave.ipynb

# ---- OS / Editors ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.code-workspace

# ---- Logs / Temp ----
*.log
logs/
tmp/
.cache/
wandb/
mlruns/  # if using MLflow locally

# ---- Data & Artifacts (keep big stuff out of Git) ----
data/raw/
data/processed/
# allow tiny samples for docs/demos:
!data/sample/
!data/sample/**

# ---- Models / Weights / Checkpoints ----
checkpoints/
runs/
outputs/
*.pt
*.pth
*.onnx
*.ckpt

# ---- Images generated by training/eval ----
reports/
figures/
media/

# ---- Gradio / Streamlit temp ----
gradio_cached_examples/
.streamlit/

# ---- PyTorch / CUDA caches ----
~/.cache/torch/
torch_cache/
